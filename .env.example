# ============================================
# AI-Powered Phishing Email Detector
# Environment Configuration
# ============================================

# Application
APP_NAME=PhishGuard AI
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000

# Security — generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
API_KEY_PREFIX=phishguard_

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_SCAN_PER_MINUTE=20

# MongoDB — set your Atlas connection string here
MONGODB_URL= 
MONGODB_DB_NAME=phishguard
MONGODB_MAX_POOL_SIZE=50
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_USE_MOCK=false

# LLM Configuration (optional - mock fallback used if not set)
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# AI Models
ML_MODEL_PATH=app/ai/models/saved
TRANSFORMER_MODEL_NAME=distilbert-base-uncased
USE_TRANSFORMER=false
USE_GPU=false

# Data
DATA_DIR=data

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Frontend
VITE_API_URL=http://localhost:8000
